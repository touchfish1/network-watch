{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Network Watch",
  "version": "0.1.0",
  "identifier": "com.codex.networkwatch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Network Watch",
        "width": 240,
        "height": 40,
        "minWidth": 160,
        "minHeight": 28,
        "maxWidth": 420,
        "maxHeight": 330,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
