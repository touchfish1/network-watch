{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Network Watch",
  "version": "0.3.45",
  "identifier": "com.codex.networkwatch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Network Watch",
        "width": 240,
        "height": 40,
        "minWidth": 160,
        "minHeight": 28,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/touchfish1/network-watch/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzNzNCODEzOTNFRDJCMUIKUldRYksrMlRFN2h6dy83dWdWdWE4dHBpUlNXdnIrNnNxbEx1amdkdU5MWVkxK0trVk4wRFBTVEEK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}














